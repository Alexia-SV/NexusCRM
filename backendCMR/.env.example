# Backend - Nexus CRM
# Copy this file to .env for local development.

NODE_ENV="development"
PORT="4000"

# PostgreSQL + Prisma
# Example: postgresql://postgres:password@localhost:5432/nexus_crm?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nexus_crm?schema=public"

# Auth tokens
JWT_ACCESS_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Cookies / CORS
FRONTEND_URL="http://localhost:5173"
COOKIE_SECURE="false"

# Password reset
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES="60"

# Email service for password recovery
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="change_me"
SMTP_FROM="Nexus CRM <no-reply@example.com>"

# Development seed users
SEED_USER_PASSWORD="change_me_seed_password"
