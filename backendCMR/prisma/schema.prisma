generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN     @map("admin")
  LIDER     @map("lider")
  OPERATIVO @map("operativo")
  CONTADOR  @map("contador")
}

enum Sex {
  MASCULINO @map("M")
  FEMENINO  @map("F")
  OTRO      @map("otro")
}

enum MaritalStatus {
  SOLTERO     @map("soltero")
  CASADO      @map("casado")
  UNION_LIBRE @map("union_libre")
  DIVORCIADO  @map("divorciado")
  VIUDO       @map("viudo")
  OTRO        @map("otro")
}

enum ContractType {
  BASE       @map("base")
  TEMPORAL   @map("temporal")
  HONORARIOS @map("honorarios")
}

enum PayrollStatus {
  BORRADOR   @map("borrador")
  EN_PROCESO @map("en_proceso")
  PAGADA     @map("pagada")
  CANCELADA  @map("cancelada")
}

enum PeriodType {
  SEMANAL   @map("semanal")
  QUINCENAL @map("quincenal")
  MENSUAL   @map("mensual")
}

enum PayrollDisabilityType {
  ENFERMEDAD_GENERAL @map("enfermedad_general")
  RIESGO_TRABAJO     @map("riesgo_trabajo")
  MATERNIDAD         @map("maternidad")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  fullName            String    @map("full_name") @db.VarChar(150)
  email               String    @unique @db.VarChar(254)
  passwordHash        String    @map("password_hash")
  role                Role
  active              Boolean   @default(true)
  mustChangePassword  Boolean   @default(true) @map("must_change_password")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz(3)
  registeredAt        DateTime  @default(now()) @map("registered_at") @db.Timestamptz(3)
  lastAccessAt        DateTime? @map("last_access_at") @db.Timestamptz(3)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  employee            Employee?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  payrolls            Payroll[]

  @@index([role, active])
  @@map("users")
}

model Employee {
  id                   String        @id @default(uuid()) @db.Uuid
  firstName            String        @map("first_name") @db.VarChar(80)
  paternalLastName     String        @map("paternal_last_name") @db.VarChar(80)
  maternalLastName     String?       @map("maternal_last_name") @db.VarChar(80)
  curp                 String        @unique @db.Char(18)
  rfc                  String?       @unique @db.VarChar(13)
  nss                  String?       @unique @db.VarChar(11)
  birthDate            DateTime      @map("birth_date") @db.Date
  sex                  Sex
  maritalStatus        MaritalStatus @map("marital_status")
  phone                String?       @db.VarChar(20)
  personalEmail        String?       @unique @map("personal_email") @db.VarChar(254)
  institutionalEmail   String?       @unique @map("institutional_email") @db.VarChar(254)
  address              String?
  position             String        @db.VarChar(100)
  department           String        @db.VarChar(100)
  hireDate             DateTime      @map("hire_date") @db.Date
  contractType         ContractType  @map("contract_type")
  dailySalary          Decimal       @map("daily_salary") @db.Decimal(12, 2)
  integratedImssSalary Decimal?      @map("integrated_imss_salary") @db.Decimal(12, 2)
  bankName             String?       @map("bank_name") @db.VarChar(100)
  clabe                String?       @unique @db.Char(18)
  afore                String?       @db.VarChar(100)
  active               Boolean       @default(true)
  userId               String?       @unique @map("user_id") @db.Uuid
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  payrollReceipts PayrollReceipt[]

  @@index([active])
  @@index([department])
  @@index([position])
  @@map("employees")
}

// Parametros fiscales/prestaciones configurables (una sola fila activa).
// Cumple la regla: los porcentajes de IMSS/ISR no deben estar hardcodeados.
model PayrollConfig {
  id                    String   @id @default(uuid()) @db.Uuid
  umaDaily              Decimal  @map("uma_daily") @db.Decimal(10, 2)
  imssEnfMatRate        Decimal  @map("imss_enf_mat_rate") @db.Decimal(6, 4)
  imssInvVidaRate       Decimal  @map("imss_inv_vida_rate") @db.Decimal(6, 4)
  imssCesVejezRate      Decimal  @map("imss_ces_vejez_rate") @db.Decimal(6, 4)
  infonavitEmployerRate Decimal  @map("infonavit_employer_rate") @db.Decimal(6, 4)
  aguinaldoDays         Int      @map("aguinaldo_days")
  vacationDays          Int      @map("vacation_days")
  primaVacacionalRate   Decimal  @map("prima_vacacional_rate") @db.Decimal(6, 4)
  fondoAhorroRate       Decimal  @map("fondo_ahorro_rate") @db.Decimal(6, 4)
  integrationFactor     Decimal  @map("integration_factor") @db.Decimal(8, 6)

  // Tope del descuento por credito INFONAVIT (% del salario percibido). 20% para creditos (Art. 97 LFT).
  infonavitMaxDiscountRate Decimal @default(20) @map("infonavit_max_discount_rate") @db.Decimal(6, 4)

  // Tope del SBC en multiplos de UMA (25) y umbral del excedente de Enf/Mat (3 UMA).
  sbcCapUma             Decimal @default(25) @map("sbc_cap_uma") @db.Decimal(6, 4)
  excedenteUmaThreshold Decimal @default(3) @map("excedente_uma_threshold") @db.Decimal(6, 4)

  // Cuotas PATRONALES (aportaciones del empleador, informativas, no descuentan al trabajador).
  imssEnfMatFixedRate           Decimal @default(20.40) @map("imss_enf_mat_fixed_rate") @db.Decimal(6, 4)
  imssEnfMatExcedentePatronRate Decimal @default(1.10) @map("imss_enf_mat_excedente_patron_rate") @db.Decimal(6, 4)
  imssPrestDineroPatronRate     Decimal @default(0.70) @map("imss_prest_dinero_patron_rate") @db.Decimal(6, 4)
  imssGastosMedPatronRate       Decimal @default(1.05) @map("imss_gastos_med_patron_rate") @db.Decimal(6, 4)
  imssInvVidaPatronRate         Decimal @default(1.75) @map("imss_inv_vida_patron_rate") @db.Decimal(6, 4)
  imssGuarderiasPatronRate      Decimal @default(1.00) @map("imss_guarderias_patron_rate") @db.Decimal(6, 4)
  imssRiesgoTrabajoRate         Decimal @default(0.54) @map("imss_riesgo_trabajo_rate") @db.Decimal(6, 4)
  retiroPatronRate              Decimal @default(2.00) @map("retiro_patron_rate") @db.Decimal(6, 4)

  // Subsidio IMSS por incapacidad (% del SBC) y dias de espera de enfermedad general.
  disabilityGeneralRate   Decimal @default(60) @map("disability_general_rate") @db.Decimal(6, 4)
  disabilityRiskRate      Decimal @default(100) @map("disability_risk_rate") @db.Decimal(7, 4)
  disabilityMaternityRate Decimal @default(100) @map("disability_maternity_rate") @db.Decimal(7, 4)
  disabilityWaitingDays   Int     @default(3) @map("disability_waiting_days")

  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("payroll_config")
}

// Tablas del ISR por periodo (SAT). Editable desde BD, sin tocar codigo.
model IsrBracket {
  id         String     @id @default(uuid()) @db.Uuid
  period     PeriodType
  lowerLimit Decimal    @map("lower_limit") @db.Decimal(12, 2)
  fixedFee   Decimal    @map("fixed_fee") @db.Decimal(12, 2)
  rate       Decimal    @db.Decimal(6, 2)
  sortOrder  Int        @map("sort_order")

  @@index([period, sortOrder])
  @@map("isr_brackets")
}

// Tabla progresiva de la cuota PATRONAL de Cesantia y Vejez por rango de SBC
// (en multiplos de UMA), segun la reforma de pensiones DOF 16-dic-2020. Editable en BD.
model CesantiaVejezPatronBracket {
  id        String  @id @default(uuid()) @db.Uuid
  lowerUma  Decimal @map("lower_uma") @db.Decimal(8, 4)
  rate      Decimal @db.Decimal(6, 4)
  sortOrder Int     @map("sort_order")

  @@index([sortOrder])
  @@map("cesantia_vejez_patron_brackets")
}

// Cabecera: una corrida de nomina por periodo que agrupa varios recibos.
model Payroll {
  id              String        @id @default(uuid()) @db.Uuid
  folio           String        @unique @db.VarChar(30)
  periodType      PeriodType    @map("period_type")
  periodStart     DateTime      @map("period_start") @db.Date
  periodEnd       DateTime      @map("period_end") @db.Date
  paymentDate     DateTime      @map("payment_date") @db.Date
  status          PayrollStatus @default(BORRADOR)
  applySavingsFund Boolean      @default(false) @map("apply_savings_fund")
  totalGross        Decimal     @default(0) @map("total_gross") @db.Decimal(14, 2)
  totalDeductions   Decimal     @default(0) @map("total_deductions") @db.Decimal(14, 2)
  totalNet          Decimal     @default(0) @map("total_net") @db.Decimal(14, 2)
  totalEmployerCost Decimal     @default(0) @map("total_employer_cost") @db.Decimal(14, 2)
  notes           String?
  createdById     String?       @map("created_by_id") @db.Uuid
  createdByName   String?       @map("created_by_name") @db.VarChar(200)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  createdBy User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  receipts  PayrollReceipt[]

  @@index([status])
  @@index([paymentDate])
  @@map("payrolls")
}

// Recibo por empleado dentro de una nomina. Guarda snapshot y desglose completo.
model PayrollReceipt {
  id        String  @id @default(uuid()) @db.Uuid
  payrollId String  @map("payroll_id") @db.Uuid
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  employeeId String   @map("employee_id") @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  // Snapshot del empleado al generar el recibo (integridad historica).
  employeeName String       @map("employee_name") @db.VarChar(200)
  curp         String       @db.Char(18)
  rfc          String?      @db.VarChar(13)
  nss          String?      @db.VarChar(11)
  clabe        String?      @db.Char(18)
  afore        String?      @db.VarChar(100)
  position     String       @db.VarChar(100)
  department   String       @db.VarChar(100)
  contractType ContractType @map("contract_type")

  workedDays  Int     @map("worked_days")
  absentDays  Int     @default(0) @map("absent_days")
  dailySalary Decimal @map("daily_salary") @db.Decimal(12, 2)
  sbc         Decimal @db.Decimal(12, 2)

  // Incapacidad (subsidio a cargo del IMSS, informativo; no lo paga la empresa)
  disabilityDays Int                    @default(0) @map("disability_days")
  disabilityType PayrollDisabilityType? @map("disability_type")
  imssSubsidy    Decimal                @default(0) @map("imss_subsidy") @db.Decimal(12, 2)

  // Percepciones
  baseSalary            Decimal @map("base_salary") @db.Decimal(12, 2)
  aguinaldoProportional Decimal @default(0) @map("aguinaldo_proportional") @db.Decimal(12, 2)
  vacationProportional  Decimal @default(0) @map("vacation_proportional") @db.Decimal(12, 2)
  vacationBonus         Decimal @default(0) @map("vacation_bonus") @db.Decimal(12, 2)
  extraPerceptions      Decimal @default(0) @map("extra_perceptions") @db.Decimal(12, 2)
  totalPerceptions      Decimal @map("total_perceptions") @db.Decimal(12, 2)

  // Deducciones
  imssEnfMat      Decimal    @default(0) @map("imss_enf_mat") @db.Decimal(12, 2)
  imssInvVida     Decimal    @default(0) @map("imss_inv_vida") @db.Decimal(12, 2)
  imssCesVejez    Decimal    @default(0) @map("imss_ces_vejez") @db.Decimal(12, 2)
  imssTotal       Decimal    @default(0) @map("imss_total") @db.Decimal(12, 2)
  isrWithholding  Decimal    @default(0) @map("isr_withholding") @db.Decimal(12, 2)
  isrTable        PeriodType @map("isr_table")
  infonavit       Decimal    @default(0) @db.Decimal(12, 2)
  savingsFund     Decimal    @default(0) @map("savings_fund") @db.Decimal(12, 2)
  otherDeductions Decimal    @default(0) @map("other_deductions") @db.Decimal(12, 2)
  totalDeductions Decimal    @map("total_deductions") @db.Decimal(12, 2)

  netPay       Decimal  @map("net_pay") @db.Decimal(12, 2)

  // Aportaciones PATRONALES (costo del empleador, informativas; no afectan el neto del trabajador)
  patronImssTotal     Decimal @default(0) @map("patron_imss_total") @db.Decimal(12, 2)
  patronRetiro        Decimal @default(0) @map("patron_retiro") @db.Decimal(12, 2)
  patronCesantiaVejez Decimal @default(0) @map("patron_cesantia_vejez") @db.Decimal(12, 2)
  patronInfonavit     Decimal @default(0) @map("patron_infonavit") @db.Decimal(12, 2)
  patronTotal         Decimal @default(0) @map("patron_total") @db.Decimal(12, 2)
  rcvAforeTotal       Decimal @default(0) @map("rcv_afore_total") @db.Decimal(12, 2)

  pdfGenerated Boolean  @default(false) @map("pdf_generated")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([payrollId, employeeId])
  @@index([employeeId])
  @@map("payroll_receipts")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  userAgent String?   @map("user_agent") @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}
